<section class="password-page">
  <div class="password-page__inner">
    <div class="password-page__logo">
      <a href="{{ routes.root_url }}">{{ shop.name }}</a>
    </div>

    <div class="password-page__content">
      {%- if section.settings.heading != blank -%}
        <h1 class="password-page__title">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p class="password-page__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_password_form -%}
      <div class="password-page__form-wrapper">
        <button class="btn btn--secondary password-page__enter-btn" data-password-toggle>
          Enter with password
        </button>
        <div class="password-page__form" data-password-form hidden>
          {%- form 'storefront_password' -%}
            {%- if form.errors -%}
              <p class="password-page__error">Wrong password. Try again.</p>
            {%- endif -%}
            <label for="password" class="visually-hidden">Password</label>
            <input type="password" id="password" name="password" class="password-page__input" placeholder="Password">
            <button type="submit" class="btn btn--primary">Enter</button>
          {%- endform -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening Soon"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "We're working hard to get ready. Check back soon."
    },
    {
      "type": "checkbox",
      "id": "show_password_form",
      "label": "Show password form",
      "default": true
    }
  ]
}
{% endschema %}
