{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign initial_savings = 0 -%}
{%- if current_variant.compare_at_price > current_variant.price -%}
  {%- assign initial_savings = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
{%- endif -%}

<!-- Sticky ATC — aparece en mobile tras 600px de scroll -->
<div class="pauze-pdp-sticky" data-pauze-sticky-atc aria-hidden="true">
  <div class="pauze-pdp-sticky__inner">
    <div class="pauze-pdp-sticky__info">
      <p class="pauze-pdp-sticky__name">{{ product.title }}</p>
      <p class="pauze-pdp-sticky__price" data-pauze-sticky-price>{{ current_variant.price | money }}</p>
    </div>
    <button type="button" class="pauze-btn pauze-btn--primary pauze-pdp-sticky__btn" id="pauze-sticky-atc-trigger">
      AGREGAR AL CARRITO
    </button>
  </div>
</div>

<section class="pauze-pdp pauze-bg-white" id="pdp-top">
  <div class="pauze-pdp__inner">

    <!-- ============================================================
         GALLERY
    ============================================================ -->
    <div class="pauze-pdp__gallery">
      <div class="pauze-pdp__gallery-main">
        {%- if product.featured_media -%}
          {{
            product.featured_media
            | image_url: width: 900
            | image_tag:
              id: 'pauze-featured-img',
              loading: 'eager',
              fetchpriority: 'high',
              width: 900,
              height: 1125,
              alt: product.featured_media.alt | escape | default: product.title,
              class: 'pauze-pdp__main-img'
          }}
        {%- else -%}
          <div class="pauze-placeholder pauze-pdp__img-placeholder" aria-hidden="true"></div>
        {%- endif -%}

        {%- if section.settings.show_image_badge and section.settings.image_badge_text != blank -%}
          <div class="pauze-pdp__gallery-badge" aria-label="{{ section.settings.image_badge_text }}">
            <span>{{ section.settings.image_badge_text }}</span>
          </div>
        {%- endif -%}
      </div>

      {%- if product.images.size > 1 -%}
        <div class="pauze-pdp__thumbs" role="list" aria-label="Imágenes del producto">
          {%- for image in product.images limit: 5 -%}
            <button
              class="pauze-pdp__thumb{% if forloop.first %} is-active{% endif %}"
              data-pauze-thumb="{{ image | image_url: width: 900 }}"
              role="listitem"
              type="button"
              aria-label="Imagen {{ forloop.index }} del producto"
            >
              {{
                image
                | image_url: width: 160
                | image_tag: loading: 'lazy', alt: image.alt | escape | default: product.title, class: 'pauze-pdp__thumb-img'
              }}
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- ============================================================
         PURCHASE BLOCK
    ============================================================ -->
    <div class="pauze-pdp__buy">

      <p class="pauze-pdp__eyebrow">{{ section.settings.eyebrow }}</p>

      <h1 class="pauze-pdp__title">{{ product.title }}</h1>

      {%- if section.settings.show_rating -%}
        <a class="pauze-pdp__rating" href="#resenas">
          <div class="pauze-stars pauze-pdp__stars" aria-label="{{ section.settings.rating_score }} de 5 estrellas">★★★★★</div>
          <span class="pauze-pdp__rating-score">{{ section.settings.rating_score }}</span>
          <span class="pauze-pdp__rating-sep">·</span>
          <span class="pauze-pdp__rating-count">{{ section.settings.rating_count }}</span>
        </a>
      {%- endif -%}

      {%- if section.settings.tagline != blank -%}
        <p class="pauze-pdp__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}

      <hr class="pauze-divider pauze-pdp__divider">

      <!-- PACK SELECTOR -->
      {%- unless product.has_only_default_variant -%}
        <div class="pauze-pdp__packs">
          <p class="pauze-pdp__packs-label">
            ELEGÍ TU PACK
            <span class="pauze-pdp__packs-hint">más unidades = más ahorro</span>
          </p>
          <div class="pauze-pdp__pack-grid" role="group" aria-label="Selector de pack">
            {%- for variant in product.variants -%}
              {%- assign v_savings = 0 -%}
              {%- if variant.compare_at_price > variant.price -%}
                {%- assign v_savings = variant.compare_at_price | minus: variant.price | times: 100 | divided_by: variant.compare_at_price -%}
              {%- endif -%}
              <button
                type="button"
                class="pauze-pdp__pack-btn{% if variant.id == current_variant.id %} is-active{% endif %}{% if section.settings.featured_variant_position == forloop.index %} pauze-pdp__pack-btn--popular{% endif %}"
                data-pauze-pack="{{ variant.id }}"
                data-pauze-price="{{ variant.price }}"
                data-pauze-price-formatted="{{ variant.price | money }}"
                data-pauze-compare="{{ variant.compare_at_price | default: 0 }}"
                data-pauze-compare-formatted="{{ variant.compare_at_price | money }}"
                data-pauze-available="{{ variant.available }}"
                data-pauze-savings="{{ v_savings }}"
                aria-pressed="{% if variant.id == current_variant.id %}true{% else %}false{% endif %}"
              >
                {%- if section.settings.featured_variant_position == forloop.index -%}
                  <span class="pauze-pdp__pack-popular-tag">MÁS ELEGIDO</span>
                {%- endif -%}
                <span class="pauze-pdp__pack-name">{{ variant.title }}</span>
                <span class="pauze-pdp__pack-price">{{ variant.price | money }}</span>
                {%- if v_savings > 0 -%}
                  <span class="pauze-pdp__pack-save">AHORRÁS {{ v_savings }}%</span>
                {%- endif -%}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endunless -%}

      <!-- PRICE ROW -->
      <div class="pauze-pdp__price-row">
        <span class="pauze-pdp__price-compare" data-pauze-price-compare {% unless current_variant.compare_at_price > current_variant.price %}style="display:none"{% endunless %}>
          {{ current_variant.compare_at_price | money }}
        </span>
        <span class="pauze-pdp__price-current" data-pauze-price-current>
          {{ current_variant.price | money }}
        </span>
        <span class="pauze-pdp__price-savings" data-pauze-price-savings {% unless initial_savings > 0 %}style="display:none"{% endunless %}>
          AHORRÁS {{ initial_savings }}%
        </span>
      </div>

      <!-- ATC FORM -->
      {%- form 'product', product, data-pauze-product-form: '', novalidate: 'novalidate', id: 'pauze-pdp-form' -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-pauze-variant-id>

        <button
          type="submit"
          id="pauze-main-atc"
          class="pauze-btn pauze-btn--primary pauze-btn--full pauze-pdp__atc"
          data-pauze-atc-btn
          {% unless current_variant.available %}disabled{% endunless %}
          aria-live="polite"
        >
          <span data-pauze-atc-text>
            {%- if current_variant.available -%}
              AGREGAR AL CARRITO &nbsp;·&nbsp; {{ current_variant.price | money }}
            {%- else -%}
              AGOTADO
            {%- endif -%}
          </span>
        </button>
      {%- endform -%}

      <p class="pauze-pdp__payment-note">
        Pagá con Mercado Pago · tarjeta · transferencia · Cuotas sin interés
      </p>

      <hr class="pauze-divider pauze-pdp__divider">

      <!-- TRUST BADGES -->
      <div class="pauze-pdp__trust" aria-label="Garantías">
        <div class="pauze-pdp__trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span>Garantía <strong>14 noches</strong></span>
        </div>
        <div class="pauze-pdp__trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M11 20A7 7 0 0 1 4 13c0-3.9 3.1-7 7-7h9v9a7 7 0 0 1-9 5z"/>
            <path d="M2 21c0-3 1.85-5.36 5-6 1.5-.27 3-.27 4 0"/>
          </svg>
          <span>Sin melatonina · <strong>activos naturales</strong></span>
        </div>
        <div class="pauze-pdp__trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="1" y="3" width="15" height="13" rx="1"/>
            <path d="M16 8h4l3 3v5h-7V8z"/>
            <circle cx="5.5" cy="18.5" r="2.5"/>
            <circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <span>Envío <strong>a todo el país</strong></span>
        </div>
        <div class="pauze-pdp__trust-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="var(--pauze-verde-pale)" stroke="var(--pauze-verde-dark)"/>
          </svg>
          <span>Hecho en <strong>Argentina</strong></span>
        </div>
      </div>

      <hr class="pauze-divider pauze-pdp__divider">

      <!-- MINI ACCORDIONS EN EL BUY BOX -->
      <div class="pauze-pdp__info-accordions">
        <details class="pauze-pdp__info-item">
          <summary class="pauze-pdp__info-trigger">
            <span class="pauze-pdp__info-trigger-label">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                <circle cx="10" cy="10" r="8"/>
                <line x1="10" y1="9" x2="10" y2="14"/>
                <circle cx="10" cy="7" r="0.8" fill="currentColor" stroke="none"/>
              </svg>
              Ingredientes
            </span>
            <svg class="pauze-pdp__info-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <polyline points="5 8 10 13 15 8"/>
            </svg>
          </summary>
          <div class="pauze-pdp__info-body rte">
            {{ section.settings.ingredients_text }}
          </div>
        </details>

        <details class="pauze-pdp__info-item">
          <summary class="pauze-pdp__info-trigger">
            <span class="pauze-pdp__info-trigger-label">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                <path d="M6 2h8l2 4H4L6 2z"/>
                <path d="M4 6v10a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V6"/>
                <path d="M8 10q2 2 4 0"/>
              </svg>
              Cómo preparar
            </span>
            <svg class="pauze-pdp__info-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <polyline points="5 8 10 13 15 8"/>
            </svg>
          </summary>
          <div class="pauze-pdp__info-body rte">
            {{ section.settings.preparation_text }}
          </div>
        </details>

        <details class="pauze-pdp__info-item">
          <summary class="pauze-pdp__info-trigger">
            <span class="pauze-pdp__info-trigger-label">
              <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                <path d="M10 1l2 6h6l-5 3.6 2 6L10 13l-5 3.6 2-6L2 7h6z"/>
              </svg>
              Envío y garantía
            </span>
            <svg class="pauze-pdp__info-chevron" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <polyline points="5 8 10 13 15 8"/>
            </svg>
          </summary>
          <div class="pauze-pdp__info-body rte">
            {{ section.settings.shipping_text }}
          </div>
        </details>
      </div>

    </div>
  </div>
</section>

<script>
  // Conectar botón sticky con el form principal
  (function() {
    var stickyBtn = document.getElementById('pauze-sticky-atc-trigger');
    var mainBtn = document.getElementById('pauze-main-atc');
    if (stickyBtn && mainBtn) {
      stickyBtn.addEventListener('click', function() {
        mainBtn.click();
      });
    }
  })();
</script>

<style>
  /* ================================================================
     STICKY ATC
  ================================================================ */
  .pauze-pdp-sticky {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: var(--pauze-white);
    border-top: 1px solid var(--pauze-arena);
    padding: 0.75rem var(--container-pad);
    transform: translateY(100%);
    transition: transform 0.3s var(--ease);
    box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
  }

  .pauze-pdp-sticky.is-visible {
    transform: translateY(0);
  }

  .pauze-pdp-sticky__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .pauze-pdp-sticky__name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--pauze-off-black);
    max-width: 100%;
  }

  .pauze-pdp-sticky__price {
    font-size: 0.8125rem;
    color: var(--pauze-gris-dark);
    max-width: 100%;
  }

  .pauze-pdp-sticky__btn {
    flex-shrink: 0;
    font-size: 0.8125rem;
    padding: 0.75rem 1.5rem;
    white-space: nowrap;
  }

  /* ================================================================
     MAIN PDP LAYOUT
  ================================================================ */
  .pauze-pdp {
    padding-block: 0;
  }

  .pauze-pdp__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    padding-block: 2rem;
  }

  /* ================================================================
     GALLERY
  ================================================================ */
  .pauze-pdp__gallery {
    margin-inline: calc(-1 * var(--container-pad));
  }

  .pauze-pdp__gallery-main {
    position: relative;
    overflow: hidden;
    background: var(--pauze-crema);
  }

  .pauze-pdp__main-img,
  .pauze-pdp__img-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }

  .pauze-pdp__gallery-badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: var(--pauze-cacao-deep);
    color: var(--pauze-white);
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-style: italic;
    font-weight: 600;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-full);
    letter-spacing: 0.02em;
  }

  .pauze-pdp__thumbs {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem var(--container-pad);
    overflow-x: auto;
    scrollbar-width: none;
    background: var(--pauze-white);
  }

  .pauze-pdp__thumbs::-webkit-scrollbar { display: none; }

  .pauze-pdp__thumb {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: var(--radius-md);
    border: 2px solid var(--pauze-arena);
    overflow: hidden;
    cursor: pointer;
    transition: border-color var(--transition);
    background: none;
    padding: 0;
  }

  .pauze-pdp__thumb.is-active,
  .pauze-pdp__thumb:hover {
    border-color: var(--pauze-verde);
  }

  .pauze-pdp__thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ================================================================
     PURCHASE BLOCK
  ================================================================ */
  .pauze-pdp__buy {
    padding-block: 1.75rem 3rem;
  }

  .pauze-pdp__eyebrow {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pauze-verde-dark);
    margin-bottom: 0.75rem;
  }

  .pauze-pdp__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 2.75rem);
    font-weight: 700;
    font-style: italic;
    color: var(--pauze-cacao);
    line-height: 1.05;
    letter-spacing: -0.01em;
    margin-bottom: 0.875rem;
  }

  .pauze-pdp__rating {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-bottom: 0.875rem;
    text-decoration: none;
    color: inherit;
  }

  .pauze-pdp__stars { font-size: 0.875rem; }

  .pauze-pdp__rating-score {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--pauze-off-black);
  }

  .pauze-pdp__rating-sep { color: var(--pauze-gris); }

  .pauze-pdp__rating-count {
    font-size: 0.8125rem;
    color: var(--pauze-verde-dark);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .pauze-pdp__tagline {
    font-size: 0.9375rem;
    color: var(--pauze-gris-dark);
    line-height: 1.65;
    max-width: 52ch;
    margin-bottom: 0;
  }

  .pauze-pdp__divider {
    margin-block: 1.5rem;
  }

  /* === PACK SELECTOR === */
  .pauze-pdp__packs-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--pauze-off-black);
    margin-bottom: 0.875rem;
  }

  .pauze-pdp__packs-hint {
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: none;
    color: var(--pauze-gris);
    margin-left: 0.25rem;
  }

  .pauze-pdp__pack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.625rem;
    margin-bottom: 1.25rem;
  }

  .pauze-pdp__pack-btn {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    padding: 0.875rem 0.5rem 0.75rem;
    border: 1.5px solid var(--pauze-arena);
    border-radius: var(--radius-md);
    background: var(--pauze-white);
    cursor: pointer;
    transition: all var(--transition);
    text-align: center;
  }

  .pauze-pdp__pack-btn:hover {
    border-color: var(--pauze-verde);
    background: var(--pauze-verde-pale);
  }

  .pauze-pdp__pack-btn.is-active {
    border-color: var(--pauze-verde);
    border-width: 2px;
    background: var(--pauze-verde-pale);
  }

  .pauze-pdp__pack-btn--popular .pauze-pdp__pack-popular-tag {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--pauze-verde-dark);
    color: var(--pauze-white);
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-full);
    white-space: nowrap;
  }

  .pauze-pdp__pack-name {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--pauze-cacao);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }

  .pauze-pdp__pack-price {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--pauze-off-black);
    line-height: 1;
  }

  .pauze-pdp__pack-save {
    font-size: 0.5625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pauze-verde-dark);
    background: rgba(59,122,44,0.12);
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-full);
  }

  /* === PRICE ROW === */
  .pauze-pdp__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .pauze-pdp__price-compare {
    font-size: 1.125rem;
    color: var(--pauze-gris);
    text-decoration: line-through;
  }

  .pauze-pdp__price-current {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-style: italic;
    font-weight: 700;
    color: var(--pauze-cacao);
    line-height: 1;
  }

  .pauze-pdp__price-savings {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--pauze-verde-dark);
    background: var(--pauze-verde-pale);
    padding: 0.25rem 0.625rem;
    border-radius: var(--radius-full);
  }

  /* === ATC === */
  .pauze-pdp__atc {
    font-size: 0.875rem;
    padding: 1.125rem 2rem;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .pauze-pdp__payment-note {
    font-size: 0.75rem;
    color: var(--pauze-gris);
    text-align: center;
    max-width: 100%;
    margin-bottom: 0;
  }

  /* === TRUST BADGES === */
  .pauze-pdp__trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }

  .pauze-pdp__trust-item {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .pauze-pdp__trust-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: var(--pauze-verde);
    margin-top: 0.1rem;
  }

  .pauze-pdp__trust-item span {
    font-size: 0.8125rem;
    color: var(--pauze-gris-dark);
    line-height: 1.4;
