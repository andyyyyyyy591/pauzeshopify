<section class="pauze-hero" id="hero">
  <div class="pauze-hero__inner">

    <!-- Columna texto -->
    <div class="pauze-hero__copy">
      <p class="pauze-hero__eyebrow">
        <span class="pauze-hero__eyebrow-dot" aria-hidden="true">●</span>
        {{ section.settings.eyebrow }}
      </p>

      <h1 class="pauze-hero__title">
        {{ section.settings.title }}
      </h1>

      <p class="pauze-hero__subtitle">{{ section.settings.subtitle }}</p>

      <ul class="pauze-hero__usps list-reset" aria-label="Beneficios clave">
        {%- for block in section.blocks -%}
          {%- if block.type == 'usp' -%}
            <li class="pauze-hero__usp" {{ block.shopify_attributes }}>
              <svg class="pauze-hero__usp-check" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="8" fill="#DBE8CC"/>
                <path d="M4.5 8.5l2.5 2.5 4.5-4.5" stroke="#2A5C20" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {{ block.settings.text }}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      <div class="pauze-hero__ctas">
        <a href="{{ section.settings.cta_primary_url }}" class="pauze-btn pauze-btn--primary pauze-hero__cta-primary">
          {{ section.settings.cta_primary_text }}
        </a>
        <a href="{{ section.settings.cta_secondary_url }}" class="pauze-btn pauze-btn--secondary">
          {{ section.settings.cta_secondary_text }}
        </a>
      </div>

      {%- if section.settings.show_social_proof -%}
      <div class="pauze-hero__proof">
        <div class="pauze-hero__proof-avatars" aria-hidden="true">
          <span class="pauze-hero__proof-avatar">M</span>
          <span class="pauze-hero__proof-avatar">C</span>
          <span class="pauze-hero__proof-avatar">J</span>
          <span class="pauze-hero__proof-avatar">B</span>
        </div>
        <div>
          <div class="pauze-stars" aria-label="4.9 de 5 estrellas">★★★★★</div>
          <p class="pauze-hero__proof-text">{{ section.settings.social_proof_text }}</p>
        </div>
      </div>
      {%- endif -%}
    </div>

    <!-- Columna imagen -->
    <div class="pauze-hero__media">
      <div class="pauze-hero__media-wrap">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1000
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              width: 1000,
              height: 1250,
              alt: section.settings.image_alt | default: shop.name,
              class: 'pauze-hero__img'
          }}
        {%- else -%}
          <div class="pauze-placeholder pauze-hero__placeholder" aria-hidden="true"></div>
        {%- endif -%}

        {%- if section.settings.badge_text != blank -%}
          <div class="pauze-hero__badge" aria-label="{{ section.settings.badge_text }}">
            <span class="pauze-hero__badge-text">{{ section.settings.badge_text }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>

  </div>
</section>

<style>
  .pauze-hero {
    background: var(--pauze-white);
    overflow: hidden;
  }

  .pauze-hero__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: grid;
    grid-template-columns: 1fr;
    min-height: 100svh;
    align-items: center;
    gap: 0;
    padding-block: 2rem;
  }

  /* === MEDIA === */
  .pauze-hero__media {
    order: -1;
    margin-inline: calc(-1 * var(--container-pad));
  }

  .pauze-hero__media-wrap {
    position: relative;
  }

  .pauze-hero__img,
  .pauze-hero__placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }

  /* Badge flotante */
  .pauze-hero__badge {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    width: 88px;
    height: 88px;
    background: var(--pauze-verde);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 0.5rem;
    animation: pauze-spin-slow 12s linear infinite;
  }

  .pauze-hero__badge-text {
    font-size: 0.5625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pauze-white);
    line-height: 1.4;
  }

  @keyframes pauze-spin-slow {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* === COPY === */
  .pauze-hero__copy {
    padding-block: clamp(2.5rem, 5vw, 4rem);
  }

  .pauze-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--pauze-verde-dark);
    background: var(--pauze-verde-pale);
    border-radius: var(--radius-full);
    padding: 0.375rem 0.875rem;
    margin-bottom: 1.5rem;
  }

  .pauze-hero__eyebrow-dot {
    font-size: 0.5rem;
    color: var(--pauze-verde);
  }

  .pauze-hero__title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, 5.5rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1.0;
    color: var(--pauze-cacao);
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .pauze-hero__subtitle {
    font-size: clamp(0.9375rem, 1.8vw, 1.0625rem);
    color: var(--pauze-gris-dark);
    line-height: 1.65;
    margin-bottom: 1.75rem;
    max-width: 44ch;
  }

  /* USPs */
  .pauze-hero__usps {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .pauze-hero__usp {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9rem;
    color: var(--pauze-off-black);
    font-weight: 500;
    max-width: 100%;
  }

  .pauze-hero__usp-check {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* CTAs */
  .pauze-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .pauze-hero__cta-primary {
    min-width: 220px;
    font-size: 0.875rem;
    padding: 1rem 2rem;
  }

  /* Social proof */
  .pauze-hero__proof {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--pauze-arena);
  }

  .pauze-hero__proof-avatars {
    display: flex;
    flex-direction: row-reverse;
  }

  .pauze-hero__proof-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--pauze-verde-pale);
    color: var(--pauze-verde-dark);
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-style: italic;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--pauze-white);
    margin-left: -8px;
    text-transform: uppercase;
  }

  .pauze-hero__proof-avatar:last-child { margin-left: 0; }

  .pauze-hero__proof .pauze-stars {
    font-size: 0.75rem;
    display: block;
    margin-bottom: 0.1rem;
  }

  .pauze-hero__proof-text {
    font-size: 0.8rem;
    color: var(--pauze-gris-dark);
    font-weight: 500;
    max-width: 100%;
  }

  /* ===================== DESKTOP ===================== */
  @media (min-width: 900px) {
    .pauze-hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 5vw, 6rem);
      padding-block: 0;
      min-height: 100svh;
    }

    .pauze-hero__media {
      order: 1;
      margin-inline: 0;
      align-self: stretch;
      display: flex;
      align-items: center;
    }

    .pauze-hero__media-wrap {
      width: 100%;
    }

    .pauze-hero__img,
    .pauze-hero__placeholder {
      aspect-ratio: unset;
      height: min(680px, 85vh);
      border-radius: var(--radius-lg);
    }

    .pauze-hero__badge {
      width: 100px;
      height: 100px;
      bottom: 1.75rem;
      right: 1.75rem;
    }

    .pauze-hero__badge-text { font-size: 0.625rem; }

    .pauze-hero__copy {
      padding-block: clamp(4rem, 6vw, 6rem);
    }

    .pauze-hero__title {
      font-size: clamp(3.5rem, 5.5vw, 5.5rem);
    }

    .pauze-hero__ctas { flex-wrap: nowrap; }
  }

  @media (min-width: 1280px) {
    .pauze-hero__inner {
      grid-template-columns: 55% 45%;
    }
  }
</style>

{% schema %}
{
  "name": "Hero principal",
  "blocks": [
    {
      "type": "usp",
      "name": "Punto clave",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Sin melatonina, sin azúcar, sin resaca"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "PAUZE PM BLEND · 30 NOCHES"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título (H1)",
      "default": "<p>Apagá la noche.<br><em>Hacé tu pausa.</em></p>"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Tu postre nocturno con L-teanina, apigenina y magnesio. Sin melatonina, sin azúcar agregada, sin resaca."
    },
    {
      "type": "header",
      "content": "CTAs"
    },
    {
      "type": "text",
      "id": "cta_primary_text",
      "label": "Texto CTA primario",
      "default": "COMPRAR · $39.900"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Link CTA primario"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "Texto CTA secundario",
      "default": "Cómo funciona →"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Link CTA secundario"
    },
    {
      "type": "header",
      "content": "Imagen"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen hero (lifestyle)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Alt de imagen"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texto badge giratorio",
      "default": "30 noches · Hacé tu pausa · Pauze PM ·"
    },
    {
      "type": "header",
      "content": "Social proof"
    },
    {
      "type": "checkbox",
      "id": "show_social_proof",
      "label": "Mostrar prueba social",
      "default": true
    },
    {
      "type": "text",
      "id": "social_proof_text",
      "label": "Texto social proof",
      "default": "+340 personas ya hacen su pausa cada noche"
    }
  ],
  "presets": [
    {
      "name": "Hero principal",
      "blocks": [
        { "type": "usp", "settings": { "text": "Sin melatonina, sin azúcar, sin resaca" } },
        { "type": "usp", "settings": { "text": "28 kcal · menos de 1g de carbohidratos" } },
        { "type": "usp", "settings": { "text": "Garantía 14 noches sin devolver el pack" } }
      ]
    }
  ]
}
{% endschema %}
