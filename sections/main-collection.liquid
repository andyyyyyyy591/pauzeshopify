<section class="collection" data-section-id="{{ section.id }}">
  <div class="collection__inner container">

    <div class="collection__header">
      {%- if collection.image -%}
        <div class="collection__banner">
          {{
            collection.image
            | image_url: width: 1400
            | image_tag: loading: 'eager', class: 'collection__banner-img', alt: collection.title | escape
          }}
        </div>
      {%- endif -%}
      <h1 class="collection__title">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <div class="collection__description rte">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_sort -%}
      <div class="collection__toolbar">
        <label for="sort-by" class="collection__sort-label">Sort by</label>
        <select id="sort-by" class="collection__sort-select" data-sort-by>
          {%- for option in collection.sort_options -%}
            <option
              value="{{ option.value | escape }}"
              {% if collection.sort_by == option.value %}selected{% endif %}
            >{{ option.name }}</option>
          {%- endfor -%}
        </select>
        <p class="collection__count">
          {{ 'collections.general.items_with_count' | t: count: collection.products_count }}
        </p>
      </div>
    {%- endif -%}

    {%- paginate collection.products by section.settings.products_per_page -%}
      {%- if collection.products.size > 0 -%}
        <ul class="collection__grid product-grid list-unstyled" data-product-grid>
          {%- for product in collection.products -%}
            <li class="product-grid__item">
              {% render 'product-card', product: product %}
            </li>
          {%- endfor -%}
        </ul>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="pagination__btn">&larr; Previous</a>
            {%- endif -%}
            <span class="pagination__info">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="pagination__btn">Next &rarr;</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- else -%}
        <p class="collection__empty">{{ 'collections.general.no_matches' | t }}</p>
      {%- endif -%}
    {%- endpaginate -%}

  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "checkbox",
      "id": "show_sort",
      "label": "Show sort by",
      "default": true
    }
  ]
}
{% endschema %}
