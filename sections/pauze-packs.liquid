<section class="pauze-packs pauze-section pauze-bg-off-white" id="packs">
  <div class="pauze-container">

    <div class="pauze-section-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="pauze-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="pauze-h2">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="pauze-packs__section-sub">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <div class="pauze-packs__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'pack' -%}
        <div class="pauze-packs__card{% if block.settings.is_featured %} pauze-packs__card--featured{% endif %}" {{ block.shopify_attributes }}>

          {%- if block.settings.tag != blank -%}
            <span class="pauze-packs__tag">{{ block.settings.tag }}</span>
          {%- endif -%}

          <div class="pauze-packs__img-wrap">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  width: 600,
                  height: 600,
                  alt: block.settings.title,
                  class: 'pauze-packs__img'
              }}
            {%- else -%}
              <div class="pauze-placeholder pauze-aspect-1-1 pauze-packs__placeholder" aria-hidden="true"></div>
            {%- endif -%}
          </div>

          <div class="pauze-packs__info">
            <p class="pauze-packs__eyebrow">{{ block.settings.eyebrow }}</p>
            <h3 class="pauze-packs__title">{{ block.settings.title }}</h3>
            <p class="pauze-packs__desc">{{ block.settings.description }}</p>

            <div class="pauze-packs__pricing">
              {%- if block.settings.compare_price != blank -%}
                <span class="pauze-packs__compare">{{ block.settings.compare_price }}</span>
              {%- endif -%}
              <span class="pauze-packs__price">{{ block.settings.price }}</span>
              {%- if block.settings.save_text != blank -%}
                <span class="pauze-packs__save-chip">{{ block.settings.save_text }}</span>
              {%- endif -%}
            </div>

            <ul class="pauze-packs__bullets list-reset">
              {%- if block.settings.bullet_1 != blank -%}
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="7" fill="var(--pauze-verde-pale)"/><path d="M4 7l2 2 4-4" stroke="var(--pauze-verde-dark)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ block.settings.bullet_1 }}
                </li>
              {%- endif -%}
              {%- if block.settings.bullet_2 != blank -%}
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="7" fill="var(--pauze-verde-pale)"/><path d="M4 7l2 2 4-4" stroke="var(--pauze-verde-dark)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ block.settings.bullet_2 }}
                </li>
              {%- endif -%}
              {%- if block.settings.bullet_3 != blank -%}
                <li>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><circle cx="7" cy="7" r="7" fill="var(--pauze-verde-pale)"/><path d="M4 7l2 2 4-4" stroke="var(--pauze-verde-dark)" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ block.settings.bullet_3 }}
                </li>
              {%- endif -%}
            </ul>

            <a href="{{ block.settings.url }}" class="pauze-btn pauze-btn--full{% if block.settings.is_featured %} pauze-btn--primary{% else %} pauze-btn--secondary{% endif %} pauze-packs__cta">
              {{ block.settings.cta_text | default: 'COMPRAR AHORA' }}
            </a>
          </div>

        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

<style>
  .pauze-packs__section-sub {
    margin-top: 0.75rem;
    color: var(--pauze-gris-dark);
  }

  .pauze-packs__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .pauze-packs__card {
    background: var(--pauze-white);
    border: 1.5px solid var(--pauze-arena);
    border-radius: var(--radius-lg);
    overflow: hidden;
    position: relative;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .pauze-packs__card:hover {
    box-shadow: 0 16px 40px rgba(46, 31, 20, 0.1);
    transform: translateY(-3px);
  }

  .pauze-packs__card--featured {
    border-color: var(--pauze-verde);
    border-width: 2px;
  }

  .pauze-packs__tag {
    position: absolute;
    top: 0.875rem;
    right: 0.875rem;
    z-index: 2;
    background: var(--pauze-verde-dark);
    color: var(--pauze-white);
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .pauze-packs__card--featured .pauze-packs__tag {
    background: var(--pauze-verde);
  }

  .pauze-packs__img-wrap {
    position: relative;
    overflow: hidden;
    background: var(--pauze-crema);
  }

  .pauze-packs__img,
  .pauze-packs__placeholder {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--ease);
  }

  .pauze-packs__card:hover .pauze-packs__img {
    transform: scale(1.03);
  }

  .pauze-packs__info {
    padding: 1.5rem;
  }

  .pauze-packs__eyebrow {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pauze-verde-dark);
    margin-bottom: 0.375rem;
  }

  .pauze-packs__title {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-style: italic;
    font-weight: 700;
    color: var(--pauze-cacao);
    margin-bottom: 0.5rem;
    line-height: 1.15;
  }

  .pauze-packs__desc {
    font-size: 0.875rem;
    color: var(--pauze-gris-dark);
    margin-bottom: 1.125rem;
    max-width: 100%;
    line-height: 1.5;
  }

  .pauze-packs__pricing {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .pauze-packs__compare {
    font-size: 0.875rem;
    color: var(--pauze-gris);
    text-decoration: line-through;
  }

  .pauze-packs__price {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--pauze-cacao);
    font-family: var(--font-display);
    font-style: italic;
  }

  .pauze-packs__save-chip {
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--pauze-verde-dark);
    background: var(--pauze-verde-pale);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pauze-packs__bullets {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 1.25rem;
  }

  .pauze-packs__bullets li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--pauze-off-black);
    font-weight: 500;
    max-width: 100%;
  }

  .pauze-packs__bullets svg {
    flex-shrink: 0;
  }

  .pauze-packs__cta {
    margin-top: 0;
  }

  @media (min-width: 640px) {
    .pauze-packs__grid {
      grid-template-columns: repeat(3, 1fr);
      align-items: start;
    }

    .pauze-packs__card--featured {
      transform: translateY(-8px);
      box-shadow: 0 20px 48px rgba(59, 122, 44, 0.12);
    }

    .pauze-packs__card--featured:hover {
      transform: translateY(-12px);
      box-shadow: 0 28px 56px rgba(59, 122, 44, 0.18);
    }
  }
</style>

