<footer class="pauze-footer">

  <!-- Newsletter banner -->
  {%- if section.settings.show_newsletter -%}
  <div class="pauze-footer__newsletter">
    <div class="pauze-container">
      <div class="pauze-footer__newsletter-inner">
        <div class="pauze-footer__newsletter-copy">
          <h3 class="pauze-footer__newsletter-title">{{ section.settings.newsletter_title }}</h3>
          <p class="pauze-footer__newsletter-sub">{{ section.settings.newsletter_sub }}</p>
        </div>
        <div class="pauze-footer__newsletter-form-wrap">
          {%- form 'customer', id: 'footer-newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter,pauze">
            <div class="pauze-footer__newsletter-form">
              <label for="footer-email" class="visually-hidden">Tu email</label>
              <input
                type="email"
                id="footer-email"
                name="contact[email]"
                class="pauze-input pauze-input--pill pauze-footer__email-input"
                placeholder="{{ section.settings.newsletter_placeholder }}"
                required
                autocomplete="email"
              >
              <button type="submit" class="pauze-btn pauze-btn--pill pauze-footer__newsletter-btn">
                {{ section.settings.newsletter_btn }}
              </button>
            </div>
            {%- if form.posted_successfully? -%}
              <p class="pauze-footer__newsletter-success">{{ section.settings.newsletter_success }}</p>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
  {%- endif -%}

  <!-- Main -->
  <div class="pauze-footer__main">
    <div class="pauze-container">
      <div class="pauze-footer__grid">

        <!-- Brand column -->
        <div class="pauze-footer__brand">
          <a href="{{ routes.root_url }}" class="pauze-footer__wordmark" aria-label="{{ shop.name }}">pauze</a>
          <p class="pauze-footer__tagline">{{ section.settings.tagline }}</p>
          <div class="pauze-footer__socials">
            {%- if settings.social_instagram != blank -%}
              <a href="{{ settings.social_instagram }}" class="pauze-footer__social-link" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor" stroke="none"/>
                </svg>
              </a>
            {%- endif -%}
            {%- if settings.social_tiktok != blank -%}
              <a href="{{ settings.social_tiktok }}" class="pauze-footer__social-link" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.34 6.34 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.79a8.18 8.18 0 0 0 4.78 1.52V6.86a4.85 4.85 0 0 1-1.01-.17z"/>
                </svg>
              </a>
            {%- endif -%}
          </div>
        </div>

        <!-- Menu columns -->
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_column' -%}
            <div class="pauze-footer__col" {{ block.shopify_attributes }}>
              <h4 class="pauze-footer__col-title">{{ block.settings.heading }}</h4>
              <ul class="pauze-footer__menu list-reset">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="pauze-footer__menu-link">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}

      </div>
    </div>
  </div>

  <!-- Payment / shipping badges -->
  <div class="pauze-footer__badges">
    <div class="pauze-container">
      <div class="pauze-footer__badges-inner">
        <div class="pauze-footer__badge-group">
          <span class="pauze-footer__badge-label">Pagás con</span>
          <div class="pauze-footer__badge-row">
            {%- assign payment_methods = 'Mercado Pago,VISA,Mastercard,AMEX,Cabal,Naranja' | split: ',' -%}
            {%- for method in payment_methods -%}
              <span class="pauze-footer__badge-chip">{{ method }}</span>
            {%- endfor -%}
          </div>
        </div>
        <div class="pauze-footer__badge-group">
          <span class="pauze-footer__badge-label">Enviamos con</span>
          <div class="pauze-footer__badge-row">
            <span class="pauze-footer__badge-chip">Andreani</span>
            <span class="pauze-footer__badge-chip">Correo Argentino</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wordmark decorativo -->
  <div class="pauze-footer__deco-wrap" aria-hidden="true">
    <span class="pauze-footer__deco-wordmark">pauze</span>
  </div>

  <!-- Legal bar -->
  <div class="pauze-footer__legal">
    <div class="pauze-container">
      <div class="pauze-footer__disclaimer">
        <p>{{ section.settings.anmat_disclaimer }}</p>
      </div>
      <div class="pauze-footer__legal-bar">
        <p class="pauze-footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }} &nbsp;&middot;&nbsp; Hecho en Argentina
        </p>
        <nav class="pauze-footer__legal-links" aria-label="Links legales">
          <a href="/pages/terminos-y-condiciones">Términos</a>
          <a href="/pages/politica-de-privacidad">Privacidad</a>
          <a href="/pages/politicas-devolucion">Garantía</a>
          <a href="/pages/politicas-envio">Envíos</a>
        </nav>
      </div>
    </div>
  </div>

</footer>

<style>
  .pauze-footer {
    background: var(--pauze-cacao-deep);
    color: var(--pauze-crema);
    margin-top: 0;
  }

  /* Newsletter banner */
  .pauze-footer__newsletter {
    background: linear-gradient(135deg, var(--pauze-verde-dark), var(--pauze-verde));
    padding: clamp(2rem, 4vw, 3rem) 0;
  }

  .pauze-footer__newsletter-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .pauze-footer__newsletter-copy {
    flex: 1;
    min-width: 240px;
  }

  .pauze-footer__newsletter-title {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-style: italic;
    font-weight: 600;
    color: var(--pauze-crema);
    margin-bottom: 0.25rem;
  }

  .pauze-footer__newsletter-sub {
    font-size: 0.875rem;
    color: rgba(246, 241, 233, 0.8);
    max-width: 100%;
  }

  .pauze-footer__newsletter-form-wrap {
    flex: 1;
    min-width: 280px;
    max-width: 440px;
  }

  .pauze-footer__newsletter-form {
    display: flex;
    gap: 0.5rem;
  }

  .pauze-footer__email-input {
    flex: 1;
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.25);
    color: var(--pauze-crema);
  }

  .pauze-footer__email-input::placeholder { color: rgba(246, 241, 233, 0.6); }
  .pauze-footer__email-input:focus { border-color: var(--pauze-crema); box-shadow: none; }

  .pauze-footer__newsletter-btn {
    background: var(--pauze-cacao-dark);
    color: var(--pauze-crema);
    border-color: var(--pauze-cacao-dark);
    white-space: nowrap;
  }

  .pauze-footer__newsletter-btn:hover {
    background: var(--pauze-cacao-deep);
    border-color: var(--pauze-cacao-deep);
    transform: translateY(-2px);
  }

  .pauze-footer__newsletter-success {
    margin-top: 0.625rem;
    font-size: 0.875rem;
    color: var(--pauze-crema);
  }

  /* Main grid */
  .pauze-footer__main {
    padding: clamp(3rem, 5vw, 4.5rem) 0 clamp(2rem, 4vw, 3rem);
    border-bottom: 1px solid rgba(246, 241, 233, 0.1);
  }

  .pauze-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media (min-width: 640px) {
    .pauze-footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .pauze-footer__grid {
      grid-template-columns: 1.5fr repeat(3, 1fr);
    }
  }

  /* Brand col */
  .pauze-footer__wordmark {
    display: block;
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 700;
    font-style: italic;
    color: var(--pauze-crema);
    margin-bottom: 0.75rem;
    text-decoration: none;
    line-height: 1;
  }

  .pauze-footer__tagline {
    font-size: 0.875rem;
    color: var(--pauze-cacao-light);
    margin-bottom: 1.5rem;
    max-width: 100%;
  }

  .pauze-footer__socials {
    display: flex;
    gap: 0.5rem;
  }

  .pauze-footer__social-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(246, 241, 233, 0.25);
    border-radius: 50%;
    color: var(--pauze-crema);
    transition: all var(--transition);
    text-decoration: none;
  }

  .pauze-footer__social-link svg { width: 16px; height: 16px; }
  .pauze-footer__social-link:hover { background: var(--pauze-crema); color: var(--pauze-cacao-deep); text-decoration: none; }

  /* Menu cols */
  .pauze-footer__col-title {
    font-family: var(--font-body);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--pauze-crema);
    margin-bottom: 1rem;
  }

  .pauze-footer__menu {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .pauze-footer__menu-link {
    font-size: 0.875rem;
    color: var(--pauze-cacao-light);
    transition: color var(--transition);
    text-decoration: none;
  }

  .pauze-footer__menu-link:hover { color: var(--pauze-crema); text-decoration: none; }

  /* Badges */
  .pauze-footer__badges {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(246, 241, 233, 0.1);
  }

  .pauze-footer__badges-inner {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem 3rem;
    align-items: center;
  }

  .pauze-footer__badge-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .pauze-footer__badge-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--pauze-gris);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .pauze-footer__badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .pauze-footer__badge-chip {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-size: 0.6875rem;
    font-weight: 600;
    background: rgba(246, 241, 233, 0.08);
    color: var(--pauze-crema);
    border: 1px solid rgba(246, 241, 233, 0.15);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  /* Decorative wordmark */
  .pauze-footer__deco-wrap {
    overflow: hidden;
    padding-top: 0.5rem;
    text-align: center;
    pointer-events: none;
    user-select: none;
  }

  .pauze-footer__deco-wordmark {
    font-family: var(--font-display);
    font-size: clamp(4rem, 14vw, 9rem);
    font-weight: 700;
    font-style: italic;
    color: var(--pauze-crema);
    opacity: 0.07;
    line-height: 1;
    display: block;
  }

  /* Legal */
  .pauze-footer__legal {
    background: var(--pauze-off-black);
    padding: 1.5rem 0;
  }

  .pauze-footer__disclaimer {
    font-size: 0.6875rem;
    color: rgba(255,255,255,0.3);
    line-height: 1.6;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    margin-bottom: 1rem;
    max-width: 100%;
  }

  .pauze-footer__disclaimer p { max-width: 100%; }

  .pauze-footer__legal-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .pauze-footer__copyright {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.35);
    max-width: 100%;
  }

  .pauze-footer__legal-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 1rem;
  }

  .pauze-footer__legal-links a {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    transition: color var(--transition);
  }

  .pauze-footer__legal-links a:hover { color: rgba(255,255,255,0.65); }
</style>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "menu_column",
      "name": "Columna de menú",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Título de columna",
          "default": "Producto"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menú",
          "default": "footer"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Mostrar banner newsletter",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Título",
      "default": "Sumate a la comunidad Pauze"
    },
    {
      "type": "text",
      "id": "newsletter_sub",
      "label": "Subtítulo",
      "default": "Recibí tips de sueño + 10% OFF en tu primera compra"
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Placeholder del input",
      "default": "Tu email"
    },
    {
      "type": "text",
      "id": "newsletter_btn",
      "label": "Texto del botón",
      "default": "SUMARME →"
    },
    {
      "type": "text",
      "id": "newsletter_success",
      "label": "Mensaje de éxito",
      "default": "¡Bienvenido/a al ritual Pauze!"
    },
    {
      "type": "header",
      "content": "Marca"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Hacé tu pausa."
    },
    {
      "type": "header",
      "content": "Disclaimer ANMAT"
    },
    {
      "type": "textarea",
      "id": "anmat_disclaimer",
      "label": "Texto legal ANMAT",
      "default": "Estas declaraciones no han sido evaluadas por ANMAT. Pauze es un complemento alimentario, no un medicamento, y no está destinado a diagnosticar, tratar, curar o prevenir ninguna enfermedad. RNPA en trámite · RNE en trámite. No utilizar durante embarazo, lactancia o en menores de 18 años. Consultá con tu médico antes de incorporarlo si tomás medicación."
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "menu_column" },
        { "type": "menu_column" },
        { "type": "menu_column" }
      ]
    }
  ]
}
{% endschema %}
