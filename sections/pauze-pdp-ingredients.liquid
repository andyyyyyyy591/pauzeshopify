<section class="pauze-pdp-ing pauze-section pauze-bg-off-white" id="ingredientes">
  <div class="pauze-container">

    <div class="pauze-section-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="pauze-eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="pauze-h2">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="pauze-pdp-ing__section-sub">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    <!-- INGREDIENT CARDS -->
    <div class="pauze-pdp-ing__cards">
      {%- for block in section.blocks -%}
        {%- if block.type == 'ingredient' -%}
        <div class="pauze-pdp-ing__card" {{ block.shopify_attributes }}>
          <div class="pauze-pdp-ing__card-top">
            <div class="pauze-pdp-ing__icon-wrap" aria-hidden="true">
              {%- case block.settings.icon -%}
                {%- when 'wave' -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="24" fill="var(--pauze-verde-pale)"/>
                    <path d="M8 28q4-8 8 0t8 0 8 0 8 0" stroke="var(--pauze-verde-dark)" stroke-width="2" stroke-linecap="round" fill="none"/>
                    <path d="M8 20q4-5 8 0t8 0 8 0 8 0" stroke="var(--pauze-verde)" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.5"/>
                  </svg>
                {%- when 'flower' -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="24" fill="var(--pauze-verde-pale)"/>
                    <circle cx="24" cy="24" r="4" fill="var(--pauze-verde-dark)"/>
                    <ellipse cx="24" cy="14" rx="3.5" ry="6" fill="var(--pauze-verde)" opacity="0.7"/>
                    <ellipse cx="24" cy="34" rx="3.5" ry="6" fill="var(--pauze-verde)" opacity="0.7"/>
                    <ellipse cx="14" cy="24" rx="6" ry="3.5" fill="var(--pauze-verde)" opacity="0.7"/>
                    <ellipse cx="34" cy="24" rx="6" ry="3.5" fill="var(--pauze-verde)" opacity="0.7"/>
                    <ellipse cx="16.9" cy="16.9" rx="3.5" ry="6" fill="var(--pauze-verde)" opacity="0.4" transform="rotate(-45 16.9 16.9)"/>
                    <ellipse cx="31.1" cy="16.9" rx="3.5" ry="6" fill="var(--pauze-verde)" opacity="0.4" transform="rotate(45 31.1 16.9)"/>
                    <ellipse cx="16.9" cy="31.1" rx="3.5" ry="6" fill="var(--pauze-verde)" opacity="0.4" transform="rotate(45 16.9 31.1)"/>
                    <ellipse cx="31.1" cy="31.1" rx="3.5" ry="6" fill="var(--pauze-verde)" opacity="0.4" transform="rotate(-45 31.1 31.1)"/>
                  </svg>
                {%- when 'mineral' -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="24" fill="var(--pauze-verde-pale)"/>
                    <polygon points="24,10 34,18 30,30 18,30 14,18" fill="none" stroke="var(--pauze-verde-dark)" stroke-width="1.8" stroke-linejoin="round"/>
                    <polygon points="24,16 30,21 28,28 20,28 18,21" fill="var(--pauze-verde)" opacity="0.25"/>
                    <line x1="24" y1="10" x2="24" y2="16" stroke="var(--pauze-verde-dark)" stroke-width="1.5"/>
                    <line x1="34" y1="18" x2="30" y2="21" stroke="var(--pauze-verde-dark)" stroke-width="1.5"/>
                    <line x1="30" y1="30" x2="28" y2="28" stroke="var(--pauze-verde-dark)" stroke-width="1.5"/>
                    <line x1="18" y1="30" x2="20" y2="28" stroke="var(--pauze-verde-dark)" stroke-width="1.5"/>
                    <line x1="14" y1="18" x2="18" y2="21" stroke="var(--pauze-verde-dark)" stroke-width="1.5"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="24" fill="var(--pauze-verde-pale)"/>
                    <path d="M14 24l7 7 13-13" stroke="var(--pauze-verde-dark)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
              {%- endcase -%}
            </div>
            <span class="pauze-pdp-ing__dose">{{ block.settings.dose }}</span>
          </div>

          <h3 class="pauze-pdp-ing__name">{{ block.settings.name }}</h3>
          <p class="pauze-pdp-ing__source">{{ block.settings.source }}</p>
          <p class="pauze-pdp-ing__benefit">{{ block.settings.benefit }}</p>

          {%- if block.settings.study != blank -%}
            <div class="pauze-pdp-ing__study">
              <svg viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <circle cx="7" cy="7" r="6.5" fill="none" stroke="var(--pauze-verde-dark)" stroke-width="1"/>
                <path d="M5 7h4M7 5v4" stroke="var(--pauze-verde-dark)" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
              <span>{{ block.settings.study }}</span>
            </div>
          {%- endif -%}
        </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- FULL FORMULA TABLE -->
    {%- if section.settings.show_formula_table -%}
      <div class="pauze-pdp-ing__table-wrap">
        <h3 class="pauze-pdp-ing__table-title">{{ section.settings.formula_title }}</h3>
        <div class="pauze-pdp-ing__table" role="table" aria-label="Tabla de ingredientes">
          <div class="pauze-pdp-ing__table-head" role="row">
            <span role="columnheader">Ingrediente</span>
            <span role="columnheader">Por porción (10g)</span>
          </div>
          {%- for block in section.blocks -%}
            {%- if block.type == 'formula_row' -%}
              <div class="pauze-pdp-ing__table-row{% if block.settings.is_active %} pauze-pdp-ing__table-row--active{% endif %}" role="row" {{ block.shopify_attributes }}>
                <span class="pauze-pdp-ing__row-name" role="cell">
                  {%- if block.settings.is_active -%}
                    <svg viewBox="0 0 12 12" fill="none" aria-hidden="true">
                      <circle cx="6" cy="6" r="6" fill="var(--pauze-verde)"/>
                      <path d="M3 6l2 2 4-4" stroke="#fff" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- endif -%}
                  {{ block.settings.ingredient }}
                </span>
                <span class="pauze-pdp-ing__row-amount" role="cell">{{ block.settings.amount }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
        <p class="pauze-pdp-ing__table-note">{{ section.settings.formula_note }}</p>
      </div>
    {%- endif -%}

    <!-- ANMAT DISCLAIMER -->
    {%- if section.settings.anmat_text != blank -%}
      <p class="pauze-pdp-ing__anmat">{{ section.settings.anmat_text }}</p>
    {%- endif -%}

  </div>
</section>

<style>
  .pauze-pdp-ing__section-sub {
    margin-top: 0.75rem;
    color: var(--pauze-gris-dark);
    max-width: 52ch;
    margin-inline: auto;
  }

  /* === INGREDIENT CARDS === */
  .pauze-pdp-ing__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .pauze-pdp-ing__card {
    background: var(--pauze-white);
    border: 1px solid var(--pauze-arena);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    position: relative;
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .pauze-pdp-ing__card:hover {
    box-shadow: 0 12px 32px rgba(46,31,20,0.08);
    transform: translateY(-2px);
  }

  .pauze-pdp-ing__card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .pauze-pdp-ing__icon-wrap {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
  }

  .pauze-pdp-ing__icon-wrap svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .pauze-pdp-ing__dose {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-style: italic;
    font-weight: 700;
    color: var(--pauze-verde-dark);
    line-height: 1;
    text-align: right;
  }

  .pauze-pdp-ing__name {
    font-family: var(--font-display);
    font-size: 1.375rem;
    font-style: italic;
    font-weight: 700;
    color: var(--pauze-cacao);
    margin-bottom: 0.25rem;
    line-height: 1.15;
  }

  .pauze-pdp-ing__source {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pauze-verde-dark);
    margin-bottom: 0.75rem;
  }

  .pauze-pdp-ing__benefit {
    font-size: 0.9rem;
    color: var(--pauze-gris-dark);
    line-height: 1.65;
    margin-bottom: 1rem;
    max-width: 100%;
  }

  .pauze-pdp-ing__study {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--pauze-verde-dark);
    background: var(--pauze-verde-pale);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius-full);
  }

  .pauze-pdp-ing__study svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* === FORMULA TABLE === */
  .pauze-pdp-ing__table-wrap {
    background: var(--pauze-white);
    border: 1px solid var(--pauze-arena);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    max-width: 640px;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  .pauze-pdp-ing__table-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-style: italic;
    font-weight: 700;
    color: var(--pauze-cacao);
    margin-bottom: 1.25rem;
  }

  .pauze-pdp-ing__table-head {
    display: flex;
    justify-content: space-between;
    padding-bottom: 0.625rem;
    border-bottom: 1.5px solid var(--pauze-arena);
    margin-bottom: 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pauze-gris);
  }

  .pauze-pdp-ing__table-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--pauze-arena);
    gap: 1rem;
  }

  .pauze-pdp-ing__table-row:last-of-type {
    border-bottom: none;
  }

  .pauze-pdp-ing__table-row--active .pauze-pdp-ing__row-name {
    font-weight: 600;
    color: var(--pauze-off-black);
  }

  .pauze-pdp-ing__row-name {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--pauze-gris-dark);
    max-width: 100%;
  }

  .pauze-pdp-ing__row-name svg {
    width: 12px;
    height: 12px;
    flex-shrink: 0;
  }

  .pauze-pdp-ing__row-amount {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--pauze-off-black);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .pauze-pdp-ing__table-note {
    font-size: 0.75rem;
    color: var(--pauze-gris);
    margin-top: 1rem;
    max-width: 100%;
    line-height: 1.5;
  }

  /* === ANMAT === */
  .pauze-pdp-ing__anmat {
    font-size: 0.75rem;
    color: var(--pauze-gris);
    text-align: center;
    max-width: 66ch;
    margin-inline: auto;
    line-height: 1.6;
  }

  @media (min-width: 768px) {
    .pauze-pdp-ing__cards {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }
</style>

{% schema %}
{
  "name": "PDP — Ingredientes",
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingrediente activo",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Ícono",
          "options": [
            { "value": "wave", "label": "Ondas (L-teanina)" },
            { "value": "flower", "label": "Flor (Apigenina)" },
            { "value": "mineral", "label": "Cristal (Magnesio)" },
            { "value": "check", "label": "Check genérico" }
          ],
          "default": "wave"
        },
        {
          "type": "text",
          "id": "dose",
          "label": "Dosis",
          "default": "200mg"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre del ingrediente",
          "default": "L-teanina"
        },
        {
          "type": "text",
          "id": "source",
          "label": "Origen / fuente",
          "default": "Extracto de hoja de té verde"
        },
        {
          "type": "textarea",
          "id": "benefit",
          "label": "Beneficio principal",
          "default": "Aumenta las ondas alpha cerebrales para una relajación atenta sin somnolencia. No adormece, baja la guardia mental."
        },
        {
          "type": "text",
          "id": "study",
          "label": "Badge de estudio (dejar vacío para ocultar)",
          "default": "Con respaldo clínico publicado"
        }
      ]
    },
    {
      "type": "formula_row",
      "name": "Fila de fórmula",
      "settings": [
        {
          "type": "text",
          "id": "ingredient",
          "label": "Ingrediente",
          "default": "L-teanina"
        },
        {
          "type": "text",
          "id": "amount",
          "label": "Cantidad por porción",
          "default": "200mg"
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "¿Es activo principal? (muestra checkmark verde)",
          "default": true
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Fórmula PM"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Título",
      "default": "<p>Cada activo, <em>en la dosis que funciona.</em></p>"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "No infusiones, no extractos diluidos. Dosis clínicas reales, publicadas en estudios peer-reviewed."
    },
    {
      "type": "header",
      "content": "Tabla de fórmula completa"
    },
    {
      "type": "checkbox",
      "id": "show_formula_table",
      "label": "Mostrar tabla de ingredientes",
      "default": true
    },
    {
      "type": "text",
      "id": "formula_title",
      "label": "Título de la tabla",
      "default": "Fórmula completa por porción (10g)"
    },
    {
      "type": "text",
      "id": "formula_note",
      "label": "Nota de la tabla",
      "default": "* Valores según declaración de fabricante. Sin gluten · Sin lactosa · Sin melatonina · Apto vegano."
    },
    {
      "type": "text",
      "id": "anmat_text",
      "label": "Disclaimer ANMAT",
      "default": "Pauze es un suplemento dietario, no un medicamento. No está destinado a diagnosticar, tratar, curar ni prevenir enfermedades. ANMAT — Suplemento Dietario."
    }
  ],
  "presets": [
    {
      "name": "PDP Pauze — Ingredientes",
      "blocks": [
        {
          "type": "ingredient",
          "settings": {
            "icon": "wave",
            "dose": "200mg",
            "name": "L-teanina",
            "source": "Extracto de hoja de té verde",
            "benefit": "Aumenta las ondas alpha cerebrales para relajación atenta sin somnolencia. Reduce la ansiedad mental sin adormecerte.",
            "study": "Asia Pacific J Clin Nutr, 2008"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "icon": "flower",
            "dose": "50mg",
            "name": "Apigenina",
            "source": "Extracto concentrado de manzanilla",
            "benefit": "Se une a receptores GABA-A en el cerebro produciendo un efecto ansiolítico suave. Apaga la mente activa.",
            "study": "Phytomedicine, 2019"
          }
        },
        {
          "type": "ingredient",
          "settings": {
            "icon": "mineral",
            "dose": "300mg",
            "name": "Magnesio Glicinato",
            "source": "Forma glicinato de alta biodisponibilidad",
            "benefit": "Mejora la calidad del sueño profundo, reduce despertares nocturnos y tiempo de latencia. No causa efecto laxante.",
            "study": "J Res Med Sci, 2012"
          }
        },
        {
          "type": "formula_row",
          "settings": { "ingredient": "L-teanina", "amount": "200mg", "is_active": true }
        },
        {
          "type": "formula_row",
          "settings": { "ingredient": "Apigenina", "amount": "50mg", "is_active": true }
        },
        {
          "type": "formula_row",
          "settings": { "ingredient": "Magnesio glicinato", "amount": "300mg", "is_active": true }
        },
        {
          "type": "formula_row",
          "settings": { "ingredient": "Cacao en polvo desgrasado", "amount": "5.2g", "is_active": false }
        },
        {
          "type": "formula_row",
          "settings": { "ingredient": "Canela ceilán", "amount": "300mg", "is_active": false }
        },
        {
          "type": "formula_row",
          "settings": { "ingredient": "Estevia (Reb A 95%)", "amount": "80mg", "is_active": false }
        },
        {
          "type": "formula_row",
          "settings": { "ingredient": "Maltodextrina (portador)", "amount": "3.1g", "is_active": false }
        }
      ]
    }
  ]
}
{% endschema %}
