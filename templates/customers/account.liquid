<section class="customer-page">
  <div class="customer-page__inner container">
    <h1 class="customer-page__title">{{ 'customer.account.title' | t }}</h1>

    <div class="account__header">
      <p>{{ customer.first_name }} {{ customer.last_name }}</p>
      <a href="{{ routes.account_logout_url }}" class="btn btn--secondary">{{ 'customer.account.logout' | t }}</a>
    </div>

    <h2>{{ 'customer.account.orders' | t }}</h2>
    {%- if customer.orders.size > 0 -%}
      <table class="account__orders-table">
        <thead>
          <tr>
            <th>Order</th>
            <th>Date</th>
            <th>Status</th>
            <th>Total</th>
          </tr>
        </thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%B %d, %Y' }}</td>
              <td>{{ order.financial_status }}</td>
              <td>{{ order.total_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    {%- else -%}
      <p>You have not placed any orders yet.</p>
    {%- endif -%}
  </div>
</section>
